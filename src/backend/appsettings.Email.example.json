{
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "noreply@hostingplatform.com",
    "FromName": "Hosting Platform Alerts",
    "EnableSsl": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=HostingPlatformDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "your-secret-key-at-least-32-characters-long-for-production",
    "Issuer": "HostingPlatform",
    "Audience": "HostingPlatformUsers",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HostingPlatform.API.Services.ServerHealthBackgroundService": "Information"
    }
  },
  "AllowedHosts": "*"
}
